{
  "name": "mushu-v2",
  "private": true,
  "version": "0.3.0",
  "productName": "Mushu",
  "description": "Mushu Electron app",
  "author": "JGaldo",
  "license": "ISC",
  "type": "module",
  "main": "main.js",
  "scripts": {
    "dev:renderer": "vite",
    "dev:electron": "wait-on http://localhost:1420/index.html && node scripts/run-electron.cjs --dev-server=http://localhost:1420",
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "build:renderer": "tsc && vite build",
    "build:icons": "node scripts/generate-icon.cjs",
    "build": "npm run build:icons && npm run build:renderer",
    "start": "electron .",
    "pack:win": "npm run build && electron-builder --win --dir",
    "dist:win": "npm run build && electron-builder --win nsis"
  },
  "build": {
    "appId": "com.juangaldo.mushu",
    "productName": "Mushu",
    "artifactName": "${productName}-Setup.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "preload.cjs",
      "package.json",
      ".env"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/uiohook-napi/**/*"
    ],
    "protocols": [
      {
        "name": "Mushu Auth Link",
        "schemes": [
          "mushu"
        ]
      }
    ],
    "win": {
      "signAndEditExecutable": false,
      "icon": "build/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Mushu",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    }
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource/dm-sans": "^5.2.8",
    "@fontsource/space-mono": "^5.2.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.525.0",
    "motion": "^12.38.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "uiohook-napi": "^1.5.2",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "concurrently": "^9.2.1",
    "electron": "^42.0.0",
    "electron-builder": "^26.8.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.4",
    "to-ico": "^1.1.5",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "wait-on": "^9.0.1"
  }
}
